generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         String        @id @default(cuid())
  email      String?       @unique
  createdAt  DateTime      @default(now())
  leagues    LeagueUser[]
  yahooToken YahooToken?
  discordUser DiscordUser?
}

model YahooToken {
  userId       String   @id
  accessToken  String
  refreshToken String
  expiresAt    DateTime
  tokenType    String
  scope        String?
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id])
}

model League {
  id        String           @id
  name      String
  sport     String
  season    Int
  snapshots LeagueSnapshot[]
  members   LeagueUser[]
  teams     Team[]
}

model LeagueUser {
  id       String @id @default(cuid())
  leagueId String
  userId   String
  role     String
  league   League @relation(fields: [leagueId], references: [id])
  user     User   @relation(fields: [userId], references: [id])

  @@unique([leagueId, userId])
}

model Team {
  id           String @id
  leagueId     String
  name         String
  fabRemaining Int
  rosterJson   Json
  league       League @relation(fields: [leagueId], references: [id])
}

model Signal {
  id       String   @id @default(cuid())
  leagueId String
  kind     String
  payload  Json
  asOf     DateTime @default(now())
  source   String
}

model Recommendation {
  id              String    @id @default(cuid())
  leagueId        String
  type            String
  summary         String
  payload         Json
  confidence      Float
  fabBid          Int?
  autoEligible    Boolean   @default(false)
  status          String    @default("STAGED")
  createdAt       DateTime  @default(now())
  executedAt      DateTime?
  executionResult Json?
}

model Decision {
  id               String    @id @default(cuid())
  recommendationId String
  action           String
  actorUserId      String?
  executedAt       DateTime?
  result           Json?
}

model LeagueSnapshot {
  id         String   @id @default(cuid())
  leagueId   String
  week       Int
  rosterJson Json
  createdAt  DateTime @default(now())
  league     League   @relation(fields: [leagueId], references: [id])
}

model DiscordUser {
  id              String   @id @default(cuid())
  discordId       String   @unique
  discordUsername String
  userId          String?  @unique
  isAuthenticated Boolean  @default(false)
  user            User?    @relation(fields: [userId], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model CostLog {
  id               String   @id @default(cuid())
  model            String
  promptTokens     Int
  completionTokens Int
  costUsd          Float
  context          String?
  createdAt        DateTime @default(now())
}
