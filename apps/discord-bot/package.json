{
  "name": "@yahoo-fantasy-bot/discord-bot",
  "version": "1.0.0",
  "description": "Discord bot interface for Yahoo Fantasy Football HeadCoach agent",
  "main": "dist/bot.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/bot.js",
    "dev": "nodemon --exec ts-node src/bot.ts",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint 'src/**/*.{ts,tsx}'",
    "format": "prettier --write 'src/**/*.{ts,tsx,js,json,md}'",
    "format:check": "prettier --check 'src/**/*.{ts,tsx,js,json,md}'",
    "deploy-commands": "ts-node src/scripts/deploy-commands.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.14.0",
    "axios": "^1.6.0",
    "discord.js": "^14.15.3",
    "dotenv": "^17.2.1",
    "express": "^4.18.2",
    "luxon": "^3.7.1",
    "node-cron": "^3.0.3",
    "pino": "^9.9.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^20.19.11",
    "@types/node-cron": "^3.0.11",
    "@typescript-eslint/eslint-plugin": "^8.41.0",
    "@typescript-eslint/parser": "^8.41.0",
    "eslint": "^9.34.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "nock": "^14.0.10",
    "nodemon": "^3.0.2",
    "prettier": "^3.6.2",
    "ts-node": "^10.9.1",
    "tsx": "^4.20.5",
    "typescript": "^5.3.2",
    "vitest": "^2.1.9",
    "vitest-mock-extended": "^2.0.2"
  }
}
