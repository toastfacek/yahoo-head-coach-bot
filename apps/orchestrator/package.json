{
  "name": "@yahoo-fantasy-bot/orchestrator",
  "version": "1.0.0",
  "description": "Orchestrator server for Yahoo Fantasy Football HeadCoach agent",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "nodemon --exec ts-node src/server.ts",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint 'src/**/*.{ts,tsx}'",
    "format": "prettier --write 'src/**/*.{ts,tsx,js,json,md}'",
    "format:check": "prettier --check 'src/**/*.{ts,tsx,js,json,md}'"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^2.0.6",
    "@prisma/client": "^6.14.0",
    "ai": "^5.0.22",
    "axios": "^1.6.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.0.1",
    "helmet": "^7.1.0",
    "luxon": "^3.7.1",
    "pino": "^9.9.0",
    "pino-http": "^10.5.0",
    "yahoo-fantasy": "^5.3.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^8.41.0",
    "@typescript-eslint/parser": "^8.41.0",
    "eslint": "^9.34.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "nodemon": "^3.0.2",
    "pino-pretty": "^13.1.1",
    "prettier": "^3.6.2",
    "prisma": "^6.14.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.3.2",
    "vitest": "^2.1.9"
  }
}
