{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Player",
  "type": "object",
  "required": [
    "player_id",
    "name",
    "team",
    "pos",
    "bye_week"
  ],
  "properties": {
    "player_id": {
      "type": "string"
    },
    "aliases": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "name": {
      "type": "string"
    },
    "team": {
      "type": "string"
    },
    "pos": {
      "type": "string",
      "enum": [
        "QB",
        "RB",
        "WR",
        "TE",
        "K",
        "DST"
      ]
    },
    "bye_week": {
      "type": "integer"
    },
    "status": {
      "type": "string"
    }
  }
}