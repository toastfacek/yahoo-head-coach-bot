{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "WeeklyFeatures",
  "type": "object",
  "required": [
    "season",
    "week",
    "player_id",
    "pos",
    "team"
  ],
  "properties": {
    "season": {
      "type": "integer"
    },
    "week": {
      "type": "integer"
    },
    "player_id": {
      "type": "string"
    },
    "team": {
      "type": "string"
    },
    "pos": {
      "type": "string"
    },
    "snap_pct": {
      "type": "number"
    },
    "target_share": {
      "type": "number"
    },
    "air_yd_share": {
      "type": "number"
    },
    "carries": {
      "type": "number"
    },
    "targets": {
      "type": "number"
    },
    "red_zone_opps": {
      "type": "number"
    },
    "goal_line_carries": {
      "type": "number"
    },
    "aDOT": {
      "type": "number"
    },
    "xFP": {
      "type": "number"
    },
    "floor_p20": {
      "type": "number"
    },
    "mean": {
      "type": "number"
    },
    "ceil_p80": {
      "type": "number"
    },
    "vol_stdev": {
      "type": "number"
    },
    "injury_status": {
      "type": "string"
    },
    "weather_flag": {
      "type": "string"
    },
    "matchup_grade": {
      "type": "number"
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}